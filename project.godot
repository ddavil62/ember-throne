; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually changed with care.

[application]

config/name="Ember Throne"
config/description="정통 판타지 택티컬 RPG"
config/version="0.1.0"
config/tags=PackedStringArray("tactical", "rpg", "fantasy")
run/main_scene="res://scenes/main/main_menu.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[internationalization]

locale/translations=PackedStringArray()
locale/fallback="ko"

[rendering]

renderer/rendering_method="forward_plus"
textures/canvas_textures/default_texture_filter=0
